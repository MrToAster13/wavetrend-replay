#!/usr/bin/env bash
# Pre-commit gate: the test suite must pass before a commit lands.
# Zero-dependency, no Husky -- just the `node --test` suite the repo ships.
#
# Enable once per clone:
#   git config core.hooksPath .githooks
#
# Bypass for a genuine emergency:  git commit --no-verify
set -euo pipefail

# Run from the repo root regardless of where git invoked the hook.
cd "$(git rev-parse --show-toplevel)"

echo "pre-commit: running node --test..."
if ! node --test; then
    echo >&2
    echo "pre-commit: tests failed -- commit aborted." >&2
    echo "Fix the failures, or bypass with 'git commit --no-verify' if you must." >&2
    exit 1
fi
echo "pre-commit: all tests passed."
